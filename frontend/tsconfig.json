{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true
	},
	"exclude": [
		"src/scripts/**",
		// Legacy/non-client storage + proxy logic is not yet type-clean.
		// We enforce backend-dep boundaries with ESLint instead of TS exclusions for CI stability.
		"src/services/**",
		"src/lib/services/**"
	]
}
