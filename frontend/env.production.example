# Production Environment Configuration
# Copy this file to env.production and update with your production values

# Authentication Configuration (SvelteKit)
AUTH_JWT_SECRET=your-super-secure-production-secret-key-here

# Application Configuration
NODE_ENV=production
BACKEND_URL=http://localhost:5000
# For production with separate backend server:
# BACKEND_URL=https://api.your-domain.com

# SvelteKit Origin (CSRF + Secure cookies)
# Must match the URL users type in the browser (scheme + host + port).
# Local Windows/Linux demo install:
#   ORIGIN=http://localhost:4001
# Public HTTPS server:
#   ORIGIN=https://demo.openshutter.org
ORIGIN=https://demo.openshutter.org

# Port Configuration
# IMPORTANT: When running with 'node build/index.js', you must set PORT as environment variable:
#   PORT=4000 node build/index.js
# Or with PM2: pm2 start build/index.js --update-env -- PORT=4000
# The adapter-node defaults to port 3000 if PORT is not set
PORT=4000
BACKEND_PORT=5000

# SvelteKit Body Size Limit (for file uploads)
# Default is 512KB. Set to 100M to match backend upload limit.
# This is REQUIRED for photo uploads larger than 512KB.
BODY_SIZE_LIMIT=100M

# Note: Storage configuration (Google Drive, AWS S3, Local Storage) 
# is managed through the admin panel and stored in the database.
# No environment variables needed for storage providers.
