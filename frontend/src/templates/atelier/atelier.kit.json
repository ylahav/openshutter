					"columnIndex": 0,
					"colSpan": 12,
					"props": {
						"instanceRef": "atelier_footer",
						"presetKey": "atelier_footer",
						"className": "atelier-footer"
					}
				}
			]
		},

		{
			"alias": "a-about",
			"slug": "a-about",
			"role": "about",
			"frontendTemplates": ["atelier"],
			"category": "system",
			"isPublished": true,
			"title": { "en": "About", "he": "אודות" },
			"subtitle": { "en": "the photographer", "he": "הצלם" },
			"layout": { "zones": ["main"] },
			"modules": [
				{
					"type": "layoutShell",
					"zone": "main",
					"rowOrder": 0,
