					"props": {
						"className": "a-albums",
						"title": { "en": "", "he": "" },
						"description": { "en": "", "he": "" },
						"albumSource": "root",
						"sortBy": "manual",
						"showCover": true,
						"coverAspect": "portrait",
						"showDescription": false,
						"showPhotoCount": false,
						"showFeaturedBadge": false,
