					"zone": "main",
					"rowOrder": 4,
					"columnIndex": 0,
					"colSpan": 12,
					"props": {
						"instanceRef": "noir_footer",
						"presetKey": "noir_footer",
						"className": "n-footer",
						"gridTemplateColumns": "1fr auto"
					}
				}
			]
		},

