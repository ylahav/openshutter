{
  "name": "openshutter",
  "version": "1.2.0",
  "type": "module",
  "description": "A comprehensive photo gallery management system with multi-storage support",
  "main": "index.js",
  "scripts": {
    "dev": "vite dev --port 4000",
    "build": "vite build",
    "preview": "vite preview --port 4000",
    "start": "node build/index.js",
    "startondev": "node -r dotenv/config build/index.js dotenv_config_path=.env.production",
    "start:local": "pnpm build && pnpm startondev",
    "startondev:https:app": "cross-env PORT=4001 ORIGIN=https://localhost:4000 node -r dotenv/config build/index.js dotenv_config_path=.env.production",
    "start:local:https": "pnpm build && concurrently --kill-others \"pnpm startondev:https:app\" \"local-ssl-proxy --source 4000 --target 4001\"",
    "design:sync": "node scripts/generate-template-from-design.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "migrate:objectid": "node src/scripts/migrate-to-objectid-references.js",
    "migrate:refs": "node src/scripts/migrate-objectid-refs-albums-photos.js"
  },
  "keywords": [
    "photo-gallery",
    "image-management",
    "sveltekit",
    "svelte",
    "nestjs",
    "mongodb",
    "google-drive",
    "aws-s3",
    "typescript"
  ],
  "author": "OpenShutter Team",
  "license": "MIT",
  "dependencies": {
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-bold": "^3.22.5",
    "@tiptap/extension-bullet-list": "^3.22.5",
    "@tiptap/extension-code": "^3.22.5",
    "@tiptap/extension-color": "^3.22.5",
    "@tiptap/extension-hard-break": "^3.22.5",
    "@tiptap/extension-heading": "^3.22.5",
    "@tiptap/extension-horizontal-rule": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-italic": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-list-item": "^3.22.5",
    "@tiptap/extension-ordered-list": "^3.22.5",
    "@tiptap/extension-strike": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-text-style": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "bits-ui": "^2.18.0",
    "canvas": "^3.2.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "exif-parser": "^0.1.12",
    "face-api.js": "^0.22.2",
    "jose": "^6.2.3",
    "marked": "^18.0.3",
    "postcss": "^8.5.13",
    "sharp": "^0.34.5",
    "svelte-dnd-action": "^0.9.69",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^4.15.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/svelte": "^5.3.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.6.0",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-svelte": "^3.17.1",
    "jsdom": "^29.1.1",
    "local-ssl-proxy": "^2.0.5",
    "sass": "^1.99.0",
    "svelte": "^5.55.5",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.0.0+sha512.5bd187500e49cc6c3d891d973b432c02b844a5eb7209172c90a517a3ef4f579ed5c23d409b699e6a9dc418ff7b2b1890e63f6d74f1d3fc49848f37779c89c84c"
}
