{
  "name": "openshutter",
  "version": "1.3.1",
  "type": "module",
  "description": "A comprehensive photo gallery management system with multi-storage support",
  "main": "index.js",
  "scripts": {
    "dev": "vite dev --port 4000",
    "build": "vite build",
    "preview": "vite preview --port 4000",
    "start": "node build/index.js",
    "startondev": "node -r dotenv/config build/index.js dotenv_config_path=.env.production",
    "start:local": "pnpm build && pnpm startondev",
    "startondev:https:app": "cross-env PORT=4001 ORIGIN=https://localhost:4000 node -r dotenv/config build/index.js dotenv_config_path=.env.production",
    "start:local:https": "pnpm build && concurrently --kill-others \"pnpm startondev:https:app\" \"local-ssl-proxy --source 4000 --target 4001\"",
    "design:sync": "node scripts/generate-template-from-design.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "migrate:objectid": "node src/scripts/migrate-to-objectid-references.js",
    "migrate:refs": "node src/scripts/migrate-objectid-refs-albums-photos.js"
  },
  "keywords": [
    "photo-gallery",
    "image-management",
    "sveltekit",
    "svelte",
    "nestjs",
    "mongodb",
    "google-drive",
    "aws-s3",
    "typescript"
  ],
  "author": "OpenShutter Team",
  "license": "MIT",
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "exif-parser": "^0.1.12",
    "face-api.js": "^0.22.2",
    "jose": "^6.2.3",
    "marked": "^18.0.5",
    "postcss": "^8.5.15",
    "sharp": "^0.35.1",
    "svelte-dnd-action": "^0.9.70",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^4.15.2",
    "@sveltejs/adapter-node": "^5.5.5",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.3",
    "@types/yauzl": "^3.4.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "jsdom": "^29.1.1",
    "local-ssl-proxy": "^2.0.5",
    "sass": "^1.101.0",
    "svelte": "^5.56.3",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
