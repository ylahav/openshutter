# Backend Environment Configuration
# Copy this file to .env and update with your production values

# MongoDB Configuration
# For MongoDB with authentication (recommended for production):
# IMPORTANT: If your password contains special characters (!, @, #, $, %, &, etc.), 
# you MUST URL-encode them in the connection string:
#   ! = %21, @ = %40, # = %23, $ = %24, % = %25, & = %26
# Example: If password is "mypass!123", use "mypass%21123"
# MONGODB_URI=mongodb://username:password@your-mongodb-host:27017/openshutter?authSource=admin
# For MongoDB without authentication:
# ⚠️ IMPORTANT: The database name is specified in the URI path (after the port)
# Format: mongodb://host:port/DATABASE_NAME
MONGODB_URI=mongodb://localhost:27017/openshutter

# Note: MONGODB_DB is NOT used by the application - the database name is in MONGODB_URI
# MONGODB_DB=openshutter  # This is for reference only, not used by code

# Authentication Configuration
AUTH_JWT_SECRET=your-super-secure-production-secret-key-here

# Application Configuration
NODE_ENV=production
PORT=5000

# CORS Configuration (optional)
# Comma-separated list of allowed frontend URLs for CORS
# FRONTEND_URL=http://localhost:4000,https://your-domain.com

# Email Configuration (optional)
# Base URL for email links (login URLs in welcome emails)
# Falls back to FRONTEND_URL if not set
# EMAIL_BASE_URL=https://your-domain.com

# Google Drive OAuth Configuration (optional)
# Base URL for Google Drive OAuth callback
# Used to construct default redirect URI: {GOOGLE_OAUTH_CALLBACK_BASE_URL}/api/auth/google/callback
# Falls back to FRONTEND_URL if not set
# GOOGLE_OAUTH_CALLBACK_BASE_URL=https://your-domain.com

# API Base URL (optional)
# Public-facing API URL for Swagger documentation and API references
# Example: https://api.yairl.com (routes to localhost:5000 via web server)
# If not set, will try to derive from FRONTEND_URL (e.g., https://yairl.com -> https://api.yairl.com)
# Falls back to http://localhost:{PORT} for development
# API_BASE_URL=https://api.your-domain.com

# Migration Configuration
# Base path for export/import operations. Only paths under this directory are allowed for security.
# If unset, defaults to ./migration-data relative to backend working directory
# MIGRATION_BASE_PATH=./migration-data
# Or use an absolute path:
# MIGRATION_BASE_PATH=/var/www/openshutter/migration-data

# Note: Storage configuration (Google Drive, AWS S3, Local Storage) 
# is managed through the admin panel and stored in the database.
# No environment variables needed for storage providers.
