{
  "name": "openshutter-backend",
  "version": "1.2.0",
  "description": "Backend API for OpenShutter",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "build": "node -e \"const fs=require('fs');try{fs.rmSync('dist',{recursive:true,force:true,maxRetries:10,retryDelay:200});}catch(e){}\" && nest build",
    "build:prod": "node -e \"const fs=require('fs');try{fs.rmSync('dist',{recursive:true,force:true,maxRetries:10,retryDelay:200});}catch(e){}\" && node --max-old-space-size=4096 node_modules/@nestjs/cli/bin/nest.js build",
    "lint": "eslint src/**/*.ts",
    "migrate:frontend-templates": "node dist/scripts/migrate-frontend-templates.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "@tensorflow-models/mobilenet": "^2.1.1",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "exif-parser": "^0.1.12",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "face-api.js": "^0.22.2",
    "googleapis": "^171.4.0",
    "jose": "^6.2.3",
    "mongoose": "^9.6.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
